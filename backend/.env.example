

DATABASE_URL="postgresql://user:password@host:5432/teachly?schema=public"
JWT_SECRET="your-jwt-secret-at-least-32-chars"
JWT_REFRESH_SECRET="your-refresh-secret-at-least-32-chars"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

FRONTEND_URL="http://localhost:3000"
APP_ENV="development"
SUPABASE_PROVISIONING_ENABLED="false"
DUAL_AUTH_ENABLED="false"
LOGIN_TRIGGERED_AUTH_MIGRATION_ENABLED="false"
LOGIN_TRIGGERED_AUTH_MIGRATION_DRY_RUN="false"
LOGIN_TRIGGERED_AUTH_MIGRATION_MAX_PER_MINUTE="0"

# Supabase backend configuration
# Backend services use only the service role key for admin/auth server operations.
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""

STORAGE_TYPE="local"
MINIO_ENDPOINT=""
MINIO_ACCESS_KEY=""
MINIO_SECRET_KEY=""
MINIO_BUCKET_NAME="teachly"

EMAIL_PROVIDER="smtp"
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Teachly <no-reply@teachly.local>"

REDIS_HOST="localhost"
REDIS_PORT="6379"

