generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────────────────────
// Static lookup tables (no institute_id, no soft delete)
// ─────────────────────────────────────────────────────────────────────────────

model Role {
  id    Int    @id @default(autoincrement()) @db.SmallInt
  name  String @unique @db.VarChar(50)
  users User[]

  @@map("roles")
}

model Feature {
  id                 Int                @id @default(autoincrement()) @db.SmallInt
  name               String             @unique @db.VarChar(100)
  instituteFeatures  InstituteFeature[]

  @@map("features")
}

// ─────────────────────────────────────────────────────────────────────────────
// institutes
// ─────────────────────────────────────────────────────────────────────────────

model Institute {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String   @db.VarChar(255)
  email     String   @unique @db.VarChar(255)
  phone     String   @db.VarChar(20)
  slug      String   @unique @db.VarChar(100)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  users             User[]
  students          Student[]
  instituteFeatures InstituteFeature[]
  studyMaterials    StudyMaterial[]
  assessments       Assessment[]
  payments          Payment[]
  notifications     Notification[]
  attendances       Attendance[]
  teachers          Teacher[]
  auditLogs         AuditLog[]

  @@index([email])
  @@index([slug])
  @@map("institutes")
}

// ─────────────────────────────────────────────────────────────────────────────
// institute_features
// ─────────────────────────────────────────────────────────────────────────────

model InstituteFeature {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  instituteId String    @map("institute_id") @db.Uuid
  featureId   Int       @map("feature_id") @db.SmallInt
  isEnabled   Boolean   @default(true) @map("is_enabled")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  institute Institute @relation(fields: [instituteId], references: [id])
  feature   Feature   @relation(fields: [featureId], references: [id])

  @@unique([instituteId, featureId])
  @@index([instituteId])
  @@map("institute_features")
}

// ─────────────────────────────────────────────────────────────────────────────
// users
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id                          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  instituteId                 String    @map("institute_id") @db.Uuid
  roleId                      Int       @map("role_id") @db.SmallInt
  name                        String    @db.VarChar(255)
  email                       String    @unique @db.VarChar(255)
  phone                       String?   @db.VarChar(20)
  authProvider                AuthProvider @default(custom) @map("auth_provider")
  authMigratedAt              DateTime? @map("auth_migrated_at") @db.Timestamptz()
  supabaseAuthId              String?   @unique @map("supabase_auth_id") @db.Uuid
  authMigrationStatus         String?   @map("auth_migration_status") @db.VarChar(20)
  pendingFeatureIds           Int[]     @default([]) @map("pending_feature_ids")
  lastMigrationError          String?   @map("last_migration_error") @db.Text
  migrationRetryCount         Int       @default(0) @map("migration_retry_count")
  lastMigrationAttempt        DateTime? @map("last_migration_attempt") @db.Timestamptz()
  passwordHash                String    @map("password_hash") @db.VarChar(255)
  sessionId                   String?   @map("session_id") @db.Uuid
  refreshTokenHash            String?   @map("refresh_token_hash") @db.VarChar(255)
  isEmailVerified             Boolean   @default(false) @map("is_email_verified")
  emailVerificationToken      String?   @map("email_verification_token") @db.VarChar(255)
  emailVerificationExpiresAt  DateTime? @map("email_verification_expires_at") @db.Timestamptz()
  passwordResetToken          String?   @map("password_reset_token") @db.VarChar(255)
  passwordResetExpiresAt      DateTime? @map("password_reset_expires_at") @db.Timestamptz()
  mustChangePassword          Boolean   @default(false) @map("must_change_password")
  isActive                    Boolean   @default(true) @map("is_active")
  lastLoginAt                 DateTime? @map("last_login_at") @db.Timestamptz()
  isDeleted                   Boolean   @default(false) @map("is_deleted")
  deletedAt                   DateTime? @map("deleted_at") @db.Timestamptz()
  deletedBy                   String?   @map("deleted_by") @db.Uuid
  createdAt                   DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt                   DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  institute Institute @relation(fields: [instituteId], references: [id])
  role      Role      @relation(fields: [roleId], references: [id])
  student   Student?
  teacher   Teacher?

  @@index([instituteId])
  @@index([email])
  @@index([sessionId])
  @@map("users")
}

// ─────────────────────────────────────────────────────────────────────────────
// students
// ─────────────────────────────────────────────────────────────────────────────

model Student {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  instituteId      String    @map("institute_id") @db.Uuid
  userId           String    @unique @map("user_id") @db.Uuid
  rollNumber       String?   @map("roll_number") @db.VarChar(50)
  class            String    @db.VarChar(100)
  school           String    @db.VarChar(255)
  dateOfBirth      DateTime? @map("date_of_birth") @db.Date
  address          String?   @db.Text
  parentName       String?   @map("parent_name") @db.VarChar(255)
  parentPhone      String?   @map("parent_phone") @db.VarChar(20)
  profilePhotoPath String?   @map("profile_photo_path") @db.VarChar(500)
  feeAmount        Decimal   @map("fee_amount") @db.Decimal(10, 2)
  joinedDate       DateTime  @default(now()) @map("joined_date") @db.Timestamptz()
  emailSent        Boolean   @default(false) @map("email_sent")
  emailSentAt      DateTime? @map("email_sent_at") @db.Timestamptz()
  emailStatus      String    @default("PENDING") @map("email_status") @db.VarChar(20)
  emailRetryCount  Int       @default(0) @map("email_retry_count")
  isDeleted        Boolean   @default(false) @map("is_deleted")
  deletedAt        DateTime? @map("deleted_at") @db.Timestamptz()
  deletedBy        String?   @map("deleted_by") @db.Uuid
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  institute           Institute            @relation(fields: [instituteId], references: [id])
  user                User                 @relation(fields: [userId], references: [id])
  submissions         Submission[]
  payments            Payment[]
  studentNotifications StudentNotification[]
  attendances         Attendance[]
  extraTimes          AssessmentExtraTime[]

  @@index([instituteId])
  @@index([userId])
  @@index([class])
  @@map("students")
}

// ─────────────────────────────────────────────────────────────────────────────
// assessment_extra_time
// ─────────────────────────────────────────────────────────────────────────────

model AssessmentExtraTime {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  assessmentId String   @map("assessment_id") @db.Uuid
  studentId    String   @map("student_id") @db.Uuid
  instituteId  String   @map("institute_id") @db.Uuid
  extraMinutes Int      @map("extra_minutes")
  reason       String?  @db.Text
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  assessment Assessment @relation(fields: [assessmentId], references: [id])
  student    Student    @relation(fields: [studentId], references: [id])

  @@unique([assessmentId, studentId])
  @@index([assessmentId])
  @@index([instituteId])
  @@map("assessment_extra_time")
}

// ─────────────────────────────────────────────────────────────────────────────
// study_materials
// ─────────────────────────────────────────────────────────────────────────────

model StudyMaterial {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  instituteId String    @map("institute_id") @db.Uuid
  title       String    @db.VarChar(255)
  subject     String    @db.VarChar(100)
  author      String?   @db.VarChar(255)
  description String?   @db.Text
  filePath    String    @map("file_path") @db.VarChar(500)
  fileSize    Int       @map("file_size")
  isHidden    Boolean   @default(false) @map("is_hidden")
  uploadedBy  String    @map("uploaded_by") @db.Uuid
  isDeleted   Boolean   @default(false) @map("is_deleted")
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz()
  deletedBy   String?   @map("deleted_by") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  institute Institute @relation(fields: [instituteId], references: [id])

  @@index([instituteId])
  @@index([instituteId, subject])
  @@map("study_materials")
}

// ─────────────────────────────────────────────────────────────────────────────
// assessments
// ─────────────────────────────────────────────────────────────────────────────

enum AssessmentStatus {
  draft
  published
  active
  closed
  evaluated
}

enum QuestionTypePreference {
  mcq
  descriptive
  both
}

enum DifficultyLevel {
  easy
  medium
  hard
}

enum AuthProvider {
  custom
  supabase
}

model Assessment {
  id               String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  instituteId      String           @map("institute_id") @db.Uuid
  title            String           @db.VarChar(255)
  description      String?          @db.Text
  instructions     String?          @db.Text
  subject          String?          @db.VarChar(100)
  totalMarks       Int              @map("total_marks")
  negativeMarking  Boolean          @default(false) @map("negative_marking")
  negativeValue    Decimal?         @map("negative_value") @db.Decimal(5, 2)
  status           AssessmentStatus @default(draft)
  startAt          DateTime?        @map("start_at") @db.Timestamptz()
  endAt            DateTime?        @map("end_at") @db.Timestamptz()
  resultsReleased         Boolean                 @default(false) @map("results_released")
  questionTypePreference  QuestionTypePreference? @map("question_type_preference")
  difficultyDistribution  Json?                   @map("difficulty_distribution")
  createdBy               String                  @map("created_by") @db.Uuid
  isDeleted        Boolean          @default(false) @map("is_deleted")
  deletedAt        DateTime?        @map("deleted_at") @db.Timestamptz()
  deletedBy        String?          @map("deleted_by") @db.Uuid
  createdAt        DateTime         @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt        DateTime         @updatedAt @map("updated_at") @db.Timestamptz()

  institute   Institute             @relation(fields: [instituteId], references: [id])
  questions   AssessmentQuestion[]
  submissions Submission[]
  extraTimes  AssessmentExtraTime[]

  @@index([instituteId])
  @@index([instituteId, status])
  @@map("assessments")
}

// ─────────────────────────────────────────────────────────────────────────────
// assessment_questions
// ─────────────────────────────────────────────────────────────────────────────

enum QuestionType {
  mcq
  descriptive
}

model AssessmentQuestion {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  assessmentId   String       @map("assessment_id") @db.Uuid
  instituteId    String       @map("institute_id") @db.Uuid
  questionNumber Int          @map("question_number")
  questionType   QuestionType @map("question_type")
  questionText   String       @map("question_text") @db.Text
  optionA        String?      @map("option_a") @db.Text
  optionB        String?      @map("option_b") @db.Text
  optionC        String?      @map("option_c") @db.Text
  optionD        String?      @map("option_d") @db.Text
  correctOption  String?      @map("correct_option") @db.VarChar(1)
  marks           Decimal          @db.Decimal(5, 2)
  difficultyLevel DifficultyLevel? @map("difficulty_level")
  aiGenerated     Boolean          @default(false) @map("ai_generated")
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt      DateTime     @updatedAt @map("updated_at") @db.Timestamptz()

  assessment Assessment @relation(fields: [assessmentId], references: [id])

  @@index([assessmentId])
  @@index([instituteId])
  @@map("assessment_questions")
}

// ─────────────────────────────────────────────────────────────────────────────
// submissions
// ─────────────────────────────────────────────────────────────────────────────

enum SubmissionStatus {
  in_progress
  submitted
  evaluated
  absent
}

model Submission {
  id             String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  assessmentId   String           @map("assessment_id") @db.Uuid
  studentId      String           @map("student_id") @db.Uuid
  instituteId    String           @map("institute_id") @db.Uuid
  status         SubmissionStatus @default(in_progress)
  answers        Json?
  uploadedFiles  Json?            @map("uploaded_files")
  totalMarks     Decimal?         @map("total_marks") @db.Decimal(8, 2)
  isFinalized    Boolean          @default(false) @map("is_finalized")
  resultReleased Boolean          @default(false) @map("result_released")
  submittedAt    DateTime?        @map("submitted_at") @db.Timestamptz()
  evaluatedAt    DateTime?        @map("evaluated_at") @db.Timestamptz()
  evaluatedBy    String?          @map("evaluated_by") @db.Uuid
  flaggedAnswers Json?            @map("flagged_answers")
  feedback       Json?
  autoSubmitted  Boolean          @default(false) @map("auto_submitted")
  lastSavedAt    DateTime?        @map("last_saved_at") @db.Timestamptz()
  createdAt      DateTime         @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt      DateTime         @updatedAt @map("updated_at") @db.Timestamptz()

  assessment Assessment @relation(fields: [assessmentId], references: [id])
  student    Student    @relation(fields: [studentId], references: [id])

  @@unique([assessmentId, studentId])
  @@index([assessmentId])
  @@index([studentId])
  @@index([instituteId])
  @@map("submissions")
}

// ─────────────────────────────────────────────────────────────────────────────
// payments
// ─────────────────────────────────────────────────────────────────────────────

enum PaymentStatus {
  pending
  paid
  overdue
}

model Payment {
  id          String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  instituteId String        @map("institute_id") @db.Uuid
  studentId   String        @map("student_id") @db.Uuid
  month       Int
  year        Int
  amount      Decimal       @db.Decimal(10, 2)
  status      PaymentStatus @default(pending)
  paidAt      DateTime?     @map("paid_at") @db.Timestamptz()
  updatedBy   String?       @map("updated_by") @db.Uuid
  notes       String?       @db.Text
  createdAt   DateTime      @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt   DateTime      @updatedAt @map("updated_at") @db.Timestamptz()

  institute Institute @relation(fields: [instituteId], references: [id])
  student   Student   @relation(fields: [studentId], references: [id])

  @@unique([studentId, month, year])
  @@index([instituteId])
  @@index([studentId])
  @@index([instituteId, status])
  @@index([instituteId, month, year])
  @@map("payments")
}

// ─────────────────────────────────────────────────────────────────────────────
// notifications
// ─────────────────────────────────────────────────────────────────────────────

enum NotificationType {
  general
  payment_reminder
  assessment_reminder
}

model Notification {
  id          String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  instituteId String           @map("institute_id") @db.Uuid
  title       String           @db.VarChar(100)
  message     String           @db.VarChar(500)
  type        NotificationType @default(general)
  createdBy   String           @map("created_by") @db.Uuid
  isDeleted   Boolean          @default(false) @map("is_deleted")
  deletedAt   DateTime?        @map("deleted_at") @db.Timestamptz()
  deletedBy   String?          @map("deleted_by") @db.Uuid
  createdAt   DateTime         @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt   DateTime         @updatedAt @map("updated_at") @db.Timestamptz()

  institute            Institute             @relation(fields: [instituteId], references: [id])
  studentNotifications StudentNotification[]

  @@index([instituteId])
  @@map("notifications")
}

// ─────────────────────────────────────────────────────────────────────────────
// student_notifications
// ─────────────────────────────────────────────────────────────────────────────

model StudentNotification {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  notificationId String    @map("notification_id") @db.Uuid
  studentId      String    @map("student_id") @db.Uuid
  isRead         Boolean   @default(false) @map("is_read")
  isDismissed    Boolean   @default(false) @map("is_dismissed")
  readAt         DateTime? @map("read_at") @db.Timestamptz()
  dismissedAt    DateTime? @map("dismissed_at") @db.Timestamptz()
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  notification Notification @relation(fields: [notificationId], references: [id])
  student      Student      @relation(fields: [studentId], references: [id])

  @@unique([notificationId, studentId])
  @@index([studentId])
  @@index([notificationId])
  @@map("student_notifications")
}

// ─────────────────────────────────────────────────────────────────────────────
// ─────────────────────────────────────────────────────────────────────────────
// attendances
// ─────────────────────────────────────────────────────────────────────────────

enum AttendanceStatus {
  present
  absent
  late
}

model Attendance {
  id          String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  instituteId String           @map("institute_id") @db.Uuid
  studentId   String           @map("student_id") @db.Uuid
  date        DateTime         @db.Date
  status      AttendanceStatus @default(present)
  markedBy    String           @map("marked_by") @db.Uuid
  notes       String?          @db.VarChar(255)
  createdAt   DateTime         @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt   DateTime         @updatedAt @map("updated_at") @db.Timestamptz()

  institute Institute @relation(fields: [instituteId], references: [id])
  student   Student   @relation(fields: [studentId], references: [id])

  @@unique([instituteId, studentId, date])
  @@index([instituteId, date])
  @@index([studentId])
  @@map("attendances")
}

// ─────────────────────────────────────────────────────────────────────────────
// teachers
// ─────────────────────────────────────────────────────────────────────────────

model Teacher {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  instituteId     String    @map("institute_id") @db.Uuid
  userId          String    @unique @map("user_id") @db.Uuid
  assignedClasses String[]  @map("assigned_classes")
  isDeleted       Boolean   @default(false) @map("is_deleted")
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz()
  deletedBy       String?   @map("deleted_by") @db.Uuid
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  institute Institute @relation(fields: [instituteId], references: [id])
  user      User      @relation(fields: [userId], references: [id])

  @@index([instituteId])
  @@map("teachers")
}

// ─────────────────────────────────────────────────────────────────────────────
// audit_logs (append-only — never updated or deleted)
// ─────────────────────────────────────────────────────────────────────────────

model AuditLog {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  instituteId String   @map("institute_id") @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  action      String   @db.VarChar(100)
  targetId    String?  @map("target_id") @db.Uuid
  targetType  String?  @map("target_type") @db.VarChar(100)
  oldValues   Json?    @map("old_values")
  newValues   Json?    @map("new_values")
  ipAddress   String?  @map("ip_address") @db.VarChar(45)
  userAgent   String?  @map("user_agent") @db.Text
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()

  institute Institute @relation(fields: [instituteId], references: [id])

  @@index([instituteId])
  @@index([userId])
  @@index([instituteId, action])
  @@index([createdAt])
  @@map("audit_logs")
}
